<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/byd_tips_title"
            android:textColor="@color/karaoke_highlight"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/byd_tips_body"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/font_size"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/fontSizeSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="18"
            android:valueTo="48"
            android:stepSize="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/highlight_color"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioGroup
            android:id="@+id/highlightColorGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/colorGold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="金色"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/colorGreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="绿色"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/colorCyan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="青色"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/colorPink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="粉色"
                android:textColor="@color/text_primary" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/overlay_position"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <RadioGroup
            android:id="@+id/positionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/posTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/position_top"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/posCenter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/position_center"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/posBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/position_bottom"
                android:textColor="@color/text_primary" />
        </RadioGroup>

        <com.car.mp3player.ui.KaraokeLyricView
            android:id="@+id/previewLyricView"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="20dp"
            android:background="@color/surface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/grant_overlay" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreviewOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/preview" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/save" />

    </LinearLayout>
</ScrollView>
