<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#1A1A1A" />
            <size android:width="280dp" android:height="280dp" />
        </shape>
    </item>
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#33FFFFFF" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <item
        android:bottom="24dp"
        android:left="24dp"
        android:right="24dp"
        android:top="24dp">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
